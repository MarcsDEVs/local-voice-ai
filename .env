# LiveKit Configuration
LIVEKIT_URL=ws://10.0.0.3:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LLM Configuration (OpenAI-compatible API)
# Change to your LLM endpoint (e.g., http://10.0.0.3:8000/v1)
LLAMA_BASE_URL=http://10.0.0.3:8000/v1
LLAMA_MODEL=qwen3-4b

# STT Configuration (OpenAI-compatible API)
# Change to your STT endpoint (e.g., http://10.0.0.3:8000/v1)
STT_PROVIDER=nemotron
STT_BASE_URL=http://10.0.0.3:8000/v1
STT_MODEL=nemotron-speech-streaming
STT_API_KEY=no-key-needed

# TTS Configuration (OpenAI-compatible API)
# Change to your TTS endpoint (e.g., http://10.0.0.3:8880/v1)
TTS_BASE_URL=http://10.0.0.3:8880/v1
TTS_MODEL=kokoro
TTS_VOICE=af_nova

# Webhook Configuration for agent delegation
# Enable webhook to delegate conversations to another agent
WEBHOOK_ENABLED=true
WEBHOOK_URL=http://10.0.0.3:5678/webhook/AI-AGI
WEBHOOK_TIMEOUT=30
